{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/projects",
        "http://127.0.0.1:3000/lab",
        "http://127.0.0.1:3000/resume"
      ],
      "startServerCommand": "npm run start -- -p 3000",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 120000
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2800
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "interaction-to-next-paint": "off",
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 350
          }
        ]
      }
    }
  }
}
