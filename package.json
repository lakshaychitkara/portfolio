{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:contracts",
    "test:contracts": "tsx --test src/tests/*.test.ts",
    "perf:baseline": "node scripts/collect-performance-baseline.mjs",
    "perf:budget": "node scripts/check-performance-budgets.mjs",
    "test:keyboard-smoke": "npx --yes playwright@1.54.2 test --project=desktop --config playwright.config.mjs scripts/keyboard-smoke.spec.mjs",
    "test:a11y": "npx --yes playwright@1.54.2 test --project=desktop --config playwright.config.mjs scripts/a11y-axe.spec.mjs",
    "test:about": "npx --yes playwright@1.54.2 test --project=desktop --config playwright.config.mjs scripts/about-reliability.spec.mjs",
    "test:visual": "npx --yes playwright@1.54.2 test --project=desktop --config playwright.config.mjs scripts/visual-regression.spec.mjs",
    "test:mobile": "npx --yes playwright@1.54.2 test --project=mobile-iphone-13 --project=mobile-pixel-5 --project=tablet-ipad-mini --config playwright.config.mjs scripts/mobile-reliability.spec.mjs",
    "test:lighthouse": "npx --yes @lhci/cli@0.14.0 autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "clsx": "^2.1.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
